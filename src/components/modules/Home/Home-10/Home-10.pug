section.section-counter.section-large
	.container 
		h2(class="text-3xl lg:text-6xl font-bold text-white") Con số nổi bật của đồ họa thuận yến
		.desc(class="text-base text-white text-start pb-10") We begin by getting to know you and your brand. Through in-depth conversations, research, and analysis.
		.grid(class="grid-cols-6 lg:grid-cols-12 gap-10 relative")
			-for(i=0;i<4;i++)
				div(class="col-span-3 lg:col-span-3 relative")
					.box-item 
						.number(class="rem:text-[40px] font-bold text-white flex items-center gap-3")
							span(class="countup" data-number="200") 200
							span(class="action") +
						.caption(class="text-base font-bold text-primary-1 pb-3 font-secondary") Cửa hàng trên toàn quốc
			.counter-highlight
				.image.relative
					img(class="" src="./img/counter.png", alt="")
					.title(class="text-xl font-bold text-white") con số <br> nổi bật

